.SUBCKT gf180mcu_fd_sc_mcu7t5v0__oai21_1 A1 A2 B ZN VDD VNW VPW VSS
X_i_1 ZN A2 net_0 VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_0 net_0 A1 ZN VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_2 VSS B net_0 VPW nmos_6p0 W=8.2e-07 L=6e-07
