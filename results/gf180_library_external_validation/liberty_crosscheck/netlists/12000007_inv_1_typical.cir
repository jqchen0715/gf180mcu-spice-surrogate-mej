.SUBCKT gf180mcu_fd_sc_mcu7t5v0__inv_1 I ZN VDD VNW VPW VSS
X_i_0 ZN I VSS VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_1 ZN I VDD VNW pmos_6p0 W=1.22e-06 L=5e-07
.ENDS

VDD vdd 0 1.8
VIN i 0 PULSE(0 1.8 24.0n 12n 12n 70.0n 160.0n)

XU1 i zn vdd vdd 0 0 gf180mcu_fd_sc_mcu7t5v0__inv_1
CLOAD zn 0 0.03162p

.tran 5p 340.0n
.measure tran tphl TRIG v(i) VAL=0.9 RISE=1 TARG v(zn) VAL=0.9 FALL=1
.measure tran tplh TRIG v(i) VAL=0.9 FALL=1 TARG v(zn) VAL=0.9 RISE=1
.measure tran i_vdd_avg AVG i(VDD) FROM=10n TO=330n
.measure tran power_avg_uW PARAM='-1.8*i_vdd_avg*1e6'
.end
