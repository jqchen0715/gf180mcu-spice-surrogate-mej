* Released GF180MCU 7-track CDL external-validation testbench
* sample_id=12000007 cell=inv_1 arc=I_to_ZN corner=typical
.title GF180MCU library cell inv_1 I_to_ZN
.option method=gear reltol=1e-4 abstol=1e-12 vntol=1e-6
.temp 25
.include "design.ngspice"
.param sw_stat_global=0 sw_stat_mismatch=0
.lib "sm141064.ngspice" typical

