X_i_1_1 net_0_2 A2 VSS VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_0_1 ZN A1 net_0_2 VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_0_0 net_0_3 A1 ZN VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_1_0 VSS A2 net_0_3 VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_3_3 ZN A2 VDD VNW pmos_6p0 W=1.13e-06 L=5e-07
X_i_2_3 VDD A1 ZN VNW pmos_6p0 W=1.13e-06 L=5e-07
X_i_2_2 ZN A1 VDD VNW pmos_6p0 W=1.13e-06 L=5e-07
