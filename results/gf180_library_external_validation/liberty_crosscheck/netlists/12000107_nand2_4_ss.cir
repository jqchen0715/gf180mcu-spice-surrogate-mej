.ENDS

VDD vdd 0 1.62
VIN a1 0 PULSE(0 1.62 24.0n 25n 25n 70.0n 160.0n)
VFIX_A2 a2 0 1.62
XU1 a1 a2 zn vdd vdd 0 0 gf180mcu_fd_sc_mcu7t5v0__nand2_4
CLOAD zn 0 0.7042p

.tran 5p 340.0n
.measure tran tphl TRIG v(a1) VAL=0.81 RISE=1 TARG v(zn) VAL=0.81 FALL=1
.measure tran tplh TRIG v(a1) VAL=0.81 FALL=1 TARG v(zn) VAL=0.81 RISE=1
.measure tran i_vdd_avg AVG i(VDD) FROM=10n TO=330n
.measure tran power_avg_uW PARAM='-1.62*i_vdd_avg*1e6'
.end
