.SUBCKT gf180mcu_fd_sc_mcu7t5v0__nand2_1 A1 A2 ZN VDD VNW VPW VSS
X_i_1 net_0 A2 VSS VPW nmos_6p0 W=8.2e-07 L=6e-07
X_i_0 ZN A1 net_0 VPW nmos_6p0 W=8.2e-07 L=6e-07
