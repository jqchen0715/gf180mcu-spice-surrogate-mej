.tran 5p 340.0n
.measure tran tphl TRIG v(a1) VAL=0.89826966 RISE=1 TARG v(zn) VAL=0.89826966 FALL=1
.measure tran tplh TRIG v(a1) VAL=0.89826966 FALL=1 TARG v(zn) VAL=0.89826966 RISE=1
