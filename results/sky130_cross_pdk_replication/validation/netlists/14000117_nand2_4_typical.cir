VDD vdd 0 1.7027549
VIN a 0 PULSE(0 1.7027549 24n 7.9987686n 7.9987686n 70n 160n)
VFIX_B b 0 1.7027549
XU1 a b 0 0 vdd vdd y sky130_fd_sc_hd__nand2_4
CLOAD y 0 0.075111919p

.tran 5p 340n
.measure tran tphl TRIG v(a) VAL=0.85137746 RISE=1 TARG v(y) VAL=0.85137746 FALL=1
.measure tran tplh TRIG v(a) VAL=0.85137746 FALL=1 TARG v(y) VAL=0.85137746 RISE=1
.measure tran i_vdd_avg AVG i(VDD) FROM=10n TO=330n
.measure tran power_avg_uW PARAM='-1.7027549*i_vdd_avg*1e6'
.end
