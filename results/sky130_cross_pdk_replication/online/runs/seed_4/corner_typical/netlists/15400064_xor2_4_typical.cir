.include "sky130-pdk/libraries/sky130_fd_sc_hd/latest/cells/xor2/sky130_fd_sc_hd__xor2_4.spice"

VDD vdd 0 1.730679
VIN a 0 PULSE(0 1.730679 24n 2.2561655n 2.2561655n 70n 160n)
VFIX_B b 0 0
XU1 a b 0 0 vdd vdd x sky130_fd_sc_hd__xor2_4
CLOAD x 0 0.20516261p

.tran 5p 340n
.measure tran tplh TRIG v(a) VAL=0.86533951 RISE=1 TARG v(x) VAL=0.86533951 RISE=1
.measure tran tphl TRIG v(a) VAL=0.86533951 FALL=1 TARG v(x) VAL=0.86533951 FALL=1
.measure tran i_vdd_avg AVG i(VDD) FROM=10n TO=330n
.measure tran power_avg_uW PARAM='-1.730679*i_vdd_avg*1e6'
.end
