VDD vdd 0 1.8534958
VIN a0 0 PULSE(0 1.8534958 24n 1.9340038n 1.9340038n 70n 160n)
VFIX_A1 a1 0 0
VFIX_S s 0 0
XU1 a0 a1 s 0 0 vdd vdd x sky130_fd_sc_hd__mux2_1
