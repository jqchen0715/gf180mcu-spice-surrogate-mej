.include "sky130-pdk/libraries/sky130_fd_sc_hd/latest/cells/inv/sky130_fd_sc_hd__inv_1.spice"

VDD vdd 0 1.7452188
VIN a 0 PULSE(0 1.7452188 24n 4.8879864n 4.8879864n 70n 160n)

XU1 a 0 0 vdd vdd y sky130_fd_sc_hd__inv_1
CLOAD y 0 0.11411073p

.tran 5p 340n
.measure tran tphl TRIG v(a) VAL=0.87260938 RISE=1 TARG v(y) VAL=0.87260938 FALL=1
.measure tran tplh TRIG v(a) VAL=0.87260938 FALL=1 TARG v(y) VAL=0.87260938 RISE=1
.measure tran i_vdd_avg AVG i(VDD) FROM=10n TO=330n
.measure tran power_avg_uW PARAM='-1.7452188*i_vdd_avg*1e6'
.end
