.tran 5p 340n
.measure tran tphl TRIG v(a) VAL=0.88496741 RISE=1 TARG v(y) VAL=0.88496741 FALL=1
.measure tran tplh TRIG v(a) VAL=0.88496741 FALL=1 TARG v(y) VAL=0.88496741 RISE=1
