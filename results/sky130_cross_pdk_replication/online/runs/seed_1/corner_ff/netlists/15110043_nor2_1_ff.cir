* SKY130 cross-PDK protocol-replication testbench
* sample_id=15110043 cell=nor2_1 source_cell=sky130_fd_sc_hd__nor2_1 corner=ff
.title SKY130 library cell nor2_1 A_to_Y__B=0
.option scale=1.0u method=gear reltol=1e-4 abstol=1e-12 vntol=1e-6
.temp 60.444543
.param mc_mm_switch=0 mc_pr_switch=0
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/nfet_01v8/sky130_fd_pr__nfet_01v8__ff.pm3.spice"
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/nfet_01v8/sky130_fd_pr__nfet_01v8__mismatch.corner.spice"
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/pfet_01v8_hvt/sky130_fd_pr__pfet_01v8_hvt__ff.pm3.spice"
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/pfet_01v8_hvt/sky130_fd_pr__pfet_01v8_hvt__mismatch.corner.spice"
.include "sky130-pdk/libraries/sky130_fd_sc_hd/latest/cells/nor2/sky130_fd_sc_hd__nor2_1.spice"

VDD vdd 0 1.689173
VIN a 0 PULSE(0 1.689173 24n 2.9323985n 2.9323985n 70n 160n)
VFIX_B b 0 0
XU1 a b 0 0 vdd vdd y sky130_fd_sc_hd__nor2_1
CLOAD y 0 0.030757772p

.tran 5p 340n
.measure tran tphl TRIG v(a) VAL=0.8445865 RISE=1 TARG v(y) VAL=0.8445865 FALL=1
.measure tran tplh TRIG v(a) VAL=0.8445865 FALL=1 TARG v(y) VAL=0.8445865 RISE=1
.measure tran i_vdd_avg AVG i(VDD) FROM=10n TO=330n
.measure tran power_avg_uW PARAM='-1.689173*i_vdd_avg*1e6'
.end
