* SKY130 cross-PDK protocol-replication testbench
* sample_id=15220039 cell=nand2_1 source_cell=sky130_fd_sc_hd__nand2_1 corner=ss
.title SKY130 library cell nand2_1 A_to_Y__B=1
.option scale=1.0u method=gear reltol=1e-4 abstol=1e-12 vntol=1e-6
.temp -22.762811
.param mc_mm_switch=0 mc_pr_switch=0
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/nfet_01v8/sky130_fd_pr__nfet_01v8__ss.pm3.spice"
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/nfet_01v8/sky130_fd_pr__nfet_01v8__mismatch.corner.spice"
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/pfet_01v8_hvt/sky130_fd_pr__pfet_01v8_hvt__ss.pm3.spice"
.include "sky130-pdk/libraries/sky130_fd_pr/latest/cells/pfet_01v8_hvt/sky130_fd_pr__pfet_01v8_hvt__mismatch.corner.spice"
.include "sky130-pdk/libraries/sky130_fd_sc_hd/latest/cells/nand2/sky130_fd_sc_hd__nand2_1.spice"

VDD vdd 0 1.7559221
VIN a 0 PULSE(0 1.7559221 24n 0.049959166n 0.049959166n 70n 160n)
VFIX_B b 0 1.7559221
XU1 a b 0 0 vdd vdd y sky130_fd_sc_hd__nand2_1
CLOAD y 0 0.095619798p

.tran 5p 340n
.measure tran tphl TRIG v(a) VAL=0.87796106 RISE=1 TARG v(y) VAL=0.87796106 FALL=1
.measure tran tplh TRIG v(a) VAL=0.87796106 FALL=1 TARG v(y) VAL=0.87796106 RISE=1
.measure tran i_vdd_avg AVG i(VDD) FROM=10n TO=330n
.measure tran power_avg_uW PARAM='-1.7559221*i_vdd_avg*1e6'
.end
